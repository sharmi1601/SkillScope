# Copy this file to `.env` and fill in your real key(s).

# ---------------------------------------------------------------------------
# Provider selection. Default is gemini (far more generous free tier).
# Use "groq" to fall back to Llama via Groq.
# ---------------------------------------------------------------------------
LLM_PROVIDER=gemini

# ---------------------------------------------------------------------------
# Gemini (recommended). Grab a free key at https://aistudio.google.com/apikey
# Free tier on gemini-2.0-flash is ample for the full 4-role / 160-job run.
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL_EXTRACTION=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Groq (fallback). Get a key at https://console.groq.com
# Note: free-tier TPD (100k/day) is tight — you'll hit the limit after ~40-50
# JDs. Use Gemini for the big runs and keep this as a backup.
# ---------------------------------------------------------------------------
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL_EXTRACTION=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# Optional: override the default throttle between LLM calls.
# Default: 4.1s for gemini, 2.1s for groq.
# ---------------------------------------------------------------------------
# LLM_THROTTLE_S=4.1
