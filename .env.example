# Minimal production environment template for SkillScope backend
# Set these values in Hugging Face Space Settings -> Variables and secrets.

# LLM provider: gemini (default) or groq
LLM_PROVIDER=gemini

# Required for gemini provider
GEMINI_API_KEY=your_gemini_api_key_here

# Optional model overrides
GEMINI_MODEL_EXTRACTION=gemini-2.5-flash-lite
GEMINI_MODEL_PLAN=gemini-2.5-flash-lite
GEMINI_MODEL_RESUME=gemini-2.5-flash-lite

# Required only when LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_EXTRACTION=llama-3.3-70b-versatile

# Optional request pacing override (seconds)
# LLM_THROTTLE_S=4.1
